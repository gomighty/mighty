{
  "type": "project",
  "require": {
    "php": "^8.4",
    "laravel/framework": "^12",
    "gomighty/laravel": "@dev"
  },
  "repositories": [
    {
      "type": "path",
      "url": "../../packages/laravel/php/laravel"
    }
  ],
  "autoload": {
    "psr-4": {
      "App\\": "app/"
    }
  },
  "config": {
    "allow-plugins": {
      "phpstan/extension-installer": true
    }
  },
  "minimum-stability": "dev",
  "prefer-stable": true
}
