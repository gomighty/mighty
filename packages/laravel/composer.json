{
  "authors": [
    {
      "name": "Amine Ilidrissi"
    }
  ],
  "require": {
    "laravel/framework": "^12",
    "php": "^8.4",
    "symfony/dependency-injection": "^5.0",
    "symfony/http-kernel": "^5.0"
  },
  "require-dev": {
    "laravel/pint": "^1.0",
    "pestphp/pest": "^4.0",
    "spatie/ray": "^1.28",
    "symplify/monorepo-builder": "^12.3"
  },
  "autoload": {
    "psr-4": {
      "Mighty\\Laravel\\": "php/laravel/src"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "Mighty\\Laravel\\Tests\\": "php/laravel/tests"
    }
  },
  "extra": {
    "laravel": {
      "providers": ["Mighty\\Laravel\\MightyServiceProvider"]
    }
  },
  "replace": {
    "gomighty/laravel": "self.version"
  },
  "minimum-stability": "dev",
  "prefer-stable": true
}
